#!/usr/bin/env ruby
# frozen_string_literal: true

require "base64"
require "json"
require "net/http"
require "open3"
require "pathname"
require "shellwords"
require "uri"
require "zlib"

class RadicchioCli
  DEFAULT_MANIFEST = "radicchio.json"
  ALLOWED_EXTENSIONS = %w[.html .css .js .json .txt .xml .svg .ico .png .jpg .jpeg .gif .webp .woff .woff2 .ttf .eot .webmanifest .mjs .wasm].freeze
  GZIP_THRESHOLD = 512 * 1024 # compress request bodies > 512 KB
  BUN_INSTALL_URL = "https://bun.sh/install".freeze

  def initialize(argv)
    @argv = argv.dup
    @manifest_path = DEFAULT_MANIFEST
    @command = nil
  end

  def run
    parse!
    manifest = load_manifest

    case @command
    when "plan"
      puts JSON.pretty_generate(plan(manifest))
    when "deploy"
      ensure_token!
      puts JSON.pretty_generate(deploy(manifest))
    when "status"
      ensure_token!
      puts JSON.pretty_generate(status(manifest))
    else
      abort usage
    end
  end

  private

  def parse!
    while @argv.first&.start_with?("--")
      flag = @argv.shift
      case flag
      when "--manifest"
        @manifest_path = @argv.shift || abort("--manifest requires a path")
      when "--help", "-h"
        puts usage
        exit 0
      else
        abort "Unknown option: #{flag}\n\n#{usage}"
      end
    end

    @command = @argv.shift || "plan"
  end

  def usage
    <<~TEXT
      Usage: Scripts/radicchio [--manifest path] <plan|deploy|status>

      Commands:
        plan    Show the files and byte counts that would be deployed
        deploy  Upload the manifest files to the configured Radicchio site
        status  Show the current Radicchio site record for this repo

      Environment:
        RADICCHIO_API_TOKEN  Radicchio API bearer token
    TEXT
  end

  def load_manifest
    path = Pathname.new(@manifest_path)
    abort "Manifest not found: #{path}" unless path.exist?

    JSON.parse(path.read).tap do |manifest|
      abort "Manifest must include site_id" unless manifest["site_id"]
      has_files = manifest["files"].is_a?(Array) && manifest["files"].any?
      has_build = manifest["build"].is_a?(Hash) && manifest["build"].any?
      abort "Manifest must include files[] or build{}" unless has_files || has_build
    end
  rescue JSON::ParserError => e
    abort "Invalid manifest JSON: #{e.message}"
  end

  def plan(manifest)
    payload = build_payload(manifest)
    {
      site_id: manifest["site_id"],
      hostname: manifest["hostname"],
      api_base: api_base(manifest),
      file_count: payload[:files].size,
      total_bytes: payload[:total_bytes],
      files: payload[:descriptors]
    }
  end

  def deploy(manifest)
    payload = build_payload(manifest)
    result = call_tool(manifest, "radicchio_deploy", site_id: manifest["site_id"], files: payload[:files])

    {
      status: "deployed",
      site_id: manifest["site_id"],
      hostname: manifest["hostname"],
      file_count: payload[:files].size,
      total_bytes: payload[:total_bytes],
      deploy: result
    }
  end

  def status(manifest)
    list = call_tool(manifest, "radicchio_list")
    site = Array(list).find { |entry| entry["site_id"].to_i == manifest["site_id"].to_i }
    abort "Site #{manifest["site_id"]} not found in Radicchio list response" unless site

    if manifest["hostname"]
      hostname = call_tool(manifest, "radicchio_check_hostname", hostname: manifest["hostname"])
      site = site.merge("hostname_status" => hostname)
    end

    site
  end

  def ensure_token!
    abort "RADICCHIO_API_TOKEN is required" if ENV["RADICCHIO_API_TOKEN"].to_s.empty?
  end

  def api_base(manifest)
    manifest["api_base"].to_s.empty? ? "https://radicchio.bitter.sh" : manifest["api_base"]
  end

  def build_payload(manifest)
    return build_output_payload(manifest) if manifest["build"].is_a?(Hash)

    static_payload(manifest)
  end

  def static_payload(manifest)
    files = {}
    descriptors = []
    total_bytes = 0

    manifest.fetch("files").each do |relative|
      path = Pathname.new(relative)
      abort "Missing deploy file: #{relative}" unless path.file?

      bytes = path.binread
      total_bytes += bytes.bytesize
      files[relative] = encode(bytes)
      descriptors << { path: relative, bytes: bytes.bytesize }
    end

    {
      files: files,
      descriptors: descriptors,
      total_bytes: total_bytes
    }
  end

  def build_output_payload(manifest)
    build = manifest.fetch("build")
    install_command = build["install"].to_s.strip
    build_command = build["command"].to_s.strip
    publish = build["publish"].to_s.strip

    abort "build.command is required" if build_command.empty?
    abort "build.publish is required" if publish.empty?

    ensure_build_tooling!(install_command, build_command)
    run_command(install_command) unless install_command.empty?
    run_command(build_command)

    output_dir = Pathname.new(publish)
    abort "Build output directory not found: #{publish}" unless output_dir.directory?

    files = {}
    descriptors = []
    total_bytes = 0

    Dir.glob("**/*", base: output_dir.to_s).sort.each do |relative|
      full = output_dir.join(relative)
      next unless full.file?
      next if relative.start_with?(".")
      next unless ALLOWED_EXTENSIONS.include?(full.extname.downcase)

      bytes = full.binread
      total_bytes += bytes.bytesize
      files[relative] = encode(bytes)
      descriptors << { path: relative, bytes: bytes.bytesize }
    end

    abort "No deployable files found in #{publish}" if files.empty?

    {
      files: files,
      descriptors: descriptors,
      total_bytes: total_bytes
    }
  end

  def run_command(command)
    puts "==> #{command}"
    stdout, status = Open3.capture2e(command)
    print stdout
    abort "Command failed: #{command}" unless status.success?
  end

  def ensure_build_tooling!(*commands)
    commands.each do |command|
      next if command.to_s.empty?

      ensure_bun_available! if command_references?(command, "bun")
    end
  end

  def command_references?(command, executable)
    Shellwords.split(command.to_s).include?(executable)
  rescue ArgumentError
    command.to_s.match?(/\b#{Regexp.escape(executable)}\b/)
  end

  # Bootstrap bun on demand so repo-owned builds do not depend on pre-baked runner images.
  def ensure_bun_available!
    install_root = bun_install_root
    install_bin = File.join(install_root, "bin")
    ENV["BUN_INSTALL"] = install_root
    prepend_path!(install_bin)
    return if executable_available?("bun")

    downloader = bun_downloader
    abort "bun is required but neither curl nor wget is available" if downloader.nil?

    puts "==> installing bun"
    stdout, status = Open3.capture2e(
      { "BUN_INSTALL" => install_root, "PATH" => ENV["PATH"].to_s },
      "bash",
      "-lc",
      "#{downloader} #{Shellwords.escape(BUN_INSTALL_URL)} | bash"
    )
    print stdout
    abort "Command failed: install bun" unless status.success?
    abort "bun install completed but bun is still unavailable" unless executable_available?("bun")
  end

  def bun_install_root
    value = ENV["BUN_INSTALL"].to_s.strip
    return value unless value.empty?

    File.expand_path("~/.bun")
  end

  def bun_downloader
    return "curl -fsSL" if executable_available?("curl")
    return "wget -qO-" if executable_available?("wget")

    nil
  end

  def prepend_path!(path)
    parts = ENV["PATH"].to_s.split(File::PATH_SEPARATOR).reject(&:empty?)
    return if parts.include?(path)

    ENV["PATH"] = ([ path ] + parts).join(File::PATH_SEPARATOR)
  end

  def executable_available?(executable)
    _stdout, status = Open3.capture2e(
      { "PATH" => ENV["PATH"].to_s },
      "bash",
      "-lc",
      "command -v #{Shellwords.escape(executable)} >/dev/null 2>&1"
    )
    status.success?
  end

  def encode(bytes)
    text = bytes.dup.force_encoding("UTF-8")
    return text if text.valid_encoding?

    "__b64__:#{Base64.strict_encode64(bytes)}"
  end

  def call_tool(manifest, name, arguments = {})
    uri = URI("#{api_base(manifest)}/api/tools/call")
    request = Net::HTTP::Post.new(uri)
    request["Authorization"] = "Bearer #{ENV.fetch("RADICCHIO_API_TOKEN")}"
    request["Content-Type"] = "application/json"

    json = JSON.generate({ name: name, arguments: arguments })
    if json.bytesize > GZIP_THRESHOLD
      request["Content-Encoding"] = "gzip"
      request.body = Zlib.gzip(json)
    else
      request.body = json
    end

    response = Net::HTTP.start(uri.host, uri.port, use_ssl: true, open_timeout: 10, read_timeout: 120) do |http|
      http.request(request)
    end

    parsed = JSON.parse(response.body)
    abort "Radicchio error: #{parsed["error"]}" if parsed["error"]

    result = parsed["result"]
    result = result.first if result.is_a?(Array)
    abort "Unexpected empty result from #{name}" if result.nil? || result == {}

    result
  rescue JSON::ParserError => e
    abort "Invalid JSON from Radicchio: #{e.message}"
  rescue KeyError => e
    abort e.message
  rescue StandardError => e
    abort "Radicchio request failed: #{e.message}"
  end
end

RadicchioCli.new(ARGV).run
